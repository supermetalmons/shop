{
  "name": "mons-shop-functions",
  "version": "1.0.0",
  "main": "lib/index.js",
  "type": "module",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('lib',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck",
    "lint": "npm run check",
    "serve": "npm run build && firebase emulators:start --only functions"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^7.0.1",
    "resend": "^6.12.2",
    "stripe": "^22.1.1",
    "tweetnacl": "^1.0.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.9.3"
  }
}
