{
  "name": "shop",
  "private": true,
  "version": "1.0.0",
  "description": "mons.shop – physically redeemable nft drops",
  "scripts": {
    "dev": "vite",
    "renderer": "vite --host 127.0.0.1 --port 5174 --open /renderer.html",
    "remotely": "node scripts/remotely.cjs",
    "build": "vite build",
    "preview": "vite preview",
    "repo-clean": "bash ./scripts/repo-clean.sh",
    "typecheck": "node -e \"require('fs').mkdirSync('.cache',{recursive:true})\" && tsc --noEmit",
    "check-irl-claims": "tsx functions/scripts/checkIrlClaims.ts",
    "assign-stripe-order-cards": "tsx functions/scripts/assignStripeOrderCards.ts",
    "unstuck-processing-orders": "npm --prefix functions run build && node --experimental-strip-types functions/scripts/unstuckProcessingOrders.ts",
    "rebuild-pack-status": "tsx functions/scripts/rebuildPackStatus.ts",
    "test-resend-notification-email": "tsx functions/scripts/sendTestResendNotificationEmail.ts",
    "wipe-drop": "node --experimental-strip-types functions/scripts/wipeDrop.ts",
    "deploy": "node --experimental-strip-types scripts/deploy-amplify.ts",
    "deploy:firebase": "firebase deploy --only firestore:rules,firestore:indexes,functions",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:firebaseNewDrops": "firebase deploy --only firestore:indexes,functions:solanaAuth,functions:getProfile,functions:listFulfillmentOrders,functions:listFulfillmentManualReviewCheckouts,functions:updateFulfillmentStatus,functions:updateFulfillmentInternalStatus,functions:listCardNft2UnrevealedCards,functions:revealDudes,functions:prepareAdminIrlRedeemTx,functions:finalizeAdminIrlRedeem,functions:prepareDeliveryTx,functions:issueReceipts,functions:recoverMyDeliveryOrders,functions:prepareIrlClaimTx,functions:claimStripeReceipt,functions:getAnonymousStripeDeliveryHistory,functions:createStripeCheckoutSession,functions:createTestStripeCheckoutSession,functions:stripeWebhook,functions:processStripeCheckoutFulfillment,functions:notifyShippersOnDeliveryReadyToShip,functions:notifyStripeCheckoutManualReview",
    "deploy-all-onchain": "node --experimental-strip-types scripts/deploy-all-onchain.ts",
    "upgrade-onchain": "node --experimental-strip-types scripts/upgrade-onchain.ts",
    "start-mint": "node --experimental-strip-types scripts/startMint.ts",
    "set-mint-prices": "node --experimental-strip-types scripts/setMintPrices.ts",
    "export_collection_files": "node --experimental-strip-types scripts/exportCollectionFiles.ts",
    "get_token_holders": "node --experimental-strip-types scripts/getTokenHolders.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/supermetalmons/shop.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/supermetalmons/shop/issues"
  },
  "homepage": "https://github.com/supermetalmons/shop#readme",
  "dependencies": {
    "@solana/spl-token": "^0.4.8",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-glow": "^0.1.18",
    "@solana/wallet-adapter-ledger": "^0.9.29",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-wallets": "^0.19.37",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "^5.90.10",
    "bs58": "^6.0.0",
    "buffer": "^6.0.3",
    "firebase": "^12.6.0",
    "jszip": "^3.10.1",
    "mp4-muxer": "^5.2.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-icons": "^5.5.0",
    "tweetnacl": "^1.0.3",
    "webm-muxer": "^5.1.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  }
}
